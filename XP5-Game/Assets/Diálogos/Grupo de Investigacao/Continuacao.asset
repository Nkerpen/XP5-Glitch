%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 28925c74c269e124dab39a3c23e16a39, type: 3}
  m_Name: Continuacao
  m_EditorClassIdentifier: Assembly-CSharp::NoDeDialogo
  mensagens:
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "s\xE9rio?"
    tempoDeDigitacao: 3
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "voc\xEA mexeu em um dispositivo que pode ser evid\xEAncia de
      um desaparecimento."
    tempoDeDigitacao: 5
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: Parem.
    tempoDeDigitacao: 1
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Ele n\xE3o est\xE1 dizendo que sabe o que aconteceu"
    tempoDeDigitacao: 1
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Ele est\xE1 dizendo que encontrou o celular do John e planejava
      devolver. "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Se ele quisesse esconder alguma coisa, n\xE3o teria falado
      com a gente."
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "A gente precisa de informa\xE7\xF5es agora, n\xE3o suspeitas."
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: "a Clara tem raz\xE3o. "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: "mas ainda n\xE3o estou entendendo. Onde voc\xEA encontrou o
      celular? "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "e h\xE1 quanto tempo ele est\xE1 sumido? "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 4e422c919cbd68844b0c1443205dc551, type: 2}
    textoDaMensagem: 'a gente nem sabe isso direito. '
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 4e422c919cbd68844b0c1443205dc551, type: 2}
    textoDaMensagem: "ele sumiu tipo\u2026 faz uns dias? uma semana? "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "n\xE3o d\xE1 pra saber exatamente quando foi a \xFAltima vez
      que algu\xE9m falou com ele. "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Eu tentei a pol\xEDcia. "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "N\xE3o levaram a s\xE9rio."
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: disseram que adulto some pra espairecer e depois aparece, que
      era pra esperar.
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: "mas o John n\xE3o \xE9 de sumir assim. "
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: 'ele estava pesquisando alguma coisa, disse que era importante. '
    tempoDeDigitacao: 4
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: "n\xE3o especificou o que era. "
    tempoDeDigitacao: 4
  escolhas:
  - textoDaEscolha: "Posso tentar ajudar a encontr\xE1-lo."
    proximoNo: {fileID: 11400000, guid: 0c14fc805e9718b439f32b30f1d4fc8f, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
  - textoDaEscolha: "Algu\xE9m deveria registrar o desaparecimento formalmente."
    proximoNo: {fileID: 11400000, guid: 5d40570ab6b32a847902202c6d85d124, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
  - textoDaEscolha: O que exatamente ele estava investigando?
    proximoNo: {fileID: 11400000, guid: 3e4a50379c91ae347b613acce9939c2e, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
