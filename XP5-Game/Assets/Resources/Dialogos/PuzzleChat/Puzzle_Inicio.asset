  m_Name: Puzzle_Inicio
  m_EditorClassIdentifier: Assembly-CSharp::NoDeDialogo
  idDaConversa: Golpista
  idDoNo: Puzzle_Inicio
  mensagens:
  - autor: {fileID: 11400000, guid: 01faac7e2e670284abf707dfaa59d1e8, type: 2}
    textoDaMensagem: "Ol\xE1, aqui \xE9 do Suporte de Seguran\xE7a Oficial."
    tempoDeDigitacao: 1
  - autor: {fileID: 11400000, guid: 01faac7e2e670284abf707dfaa59d1e8, type: 2}
    textoDaMensagem: Identificamos um acesso suspeito na sua conta a partir de outro
      estado.
    tempoDeDigitacao: 2
  - autor: {fileID: 11400000, guid: 01faac7e2e670284abf707dfaa59d1e8, type: 2}
    textoDaMensagem: "Para evitar o bloqueio permanente do seu aplicativo, por favor,
      nos confirme o c\xF3digo de 6 d\xEDgitos que acabou de chegar por SMS."
    tempoDeDigitacao: 3
  escolhas:
  - textoDaEscolha: "Meu Deus, ok! O c\xF3digo \xE9 482-910."
    proximoNo: {fileID: 0}
    encerraPuzzle: 1
    jogadorGanhou: 0
  - textoDaEscolha: "Vou confirmar isso direto nas configura\xE7\xF5es do meu aplicativo
      oficial."
    proximoNo: {fileID: 0}
    encerraPuzzle: 1
    jogadorGanhou: 1
  - textoDaEscolha: "Suporte oficial? Mas o n\xFAmero de voc\xEAs n\xE3o tem o selo
      de verifica\xE7\xE3o verde."
    proximoNo: {fileID: 11400000, guid: e2fb5609af9f1af4890d35e061781c93, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
