  m_Script: {fileID: 11500000, guid: 28925c74c269e124dab39a3c23e16a39, type: 3}
  m_Name: DialogoGrupo_Rota2
  m_EditorClassIdentifier: Assembly-CSharp::NoDeDialogo
  idDaConversa: GrupoInicio
  idDoNo: DialogoGrupo_Rota2
  mensagens:
  - autor: {fileID: 11400000, guid: 4e422c919cbd68844b0c1443205dc551, type: 2}
    textoDaMensagem: "como assim n\xE3o \xE9 o John?"
    tempoDeDigitacao: 2
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Quem \xE9 voc\xEA?"
    tempoDeDigitacao: 1
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "E porque est\xE1 com o celular dele?"
    tempoDeDigitacao: 2.5
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "onde voc\xEA conseguiu esse celular?"
    tempoDeDigitacao: 2
  - autor: {fileID: 11400000, guid: 4e422c919cbd68844b0c1443205dc551, type: 2}
    textoDaMensagem: "cara\u2026 isso n\xE3o t\xE1 fazendo sentido\r\n"
    tempoDeDigitacao: 2
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: 'calma, charles.

'
    tempoDeDigitacao: 1.5
  - autor: {fileID: 11400000, guid: 14c0ac273066fd94ca4e749fb1b0904a, type: 2}
    textoDaMensagem: "explica direito o que est\xE1 acontecendo."
    tempoDeDigitacao: 2
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Voc\xEA n\xE3o \xE9 o John."
    tempoDeDigitacao: 1.5
  - autor: {fileID: 11400000, guid: a047b8c4124616c44a84795fd6f3a21a, type: 2}
    textoDaMensagem: "Ent\xE3o quem \xE9 voc\xEA?"
    tempoDeDigitacao: 1.5
  - autor: {fileID: 11400000, guid: 86feeb07780abc3478b22f3455e54446, type: 2}
    textoDaMensagem: "e por que voc\xEA est\xE1 com o celular dele?\r\n"
    tempoDeDigitacao: 2.5
  escolhas:
  - textoDaEscolha: "Encontrei o celular no ch\xE3o e peguei pra tentar achar o dono."
    proximoNo: {fileID: 11400000, guid: aef9669d132710a4aa4a47db8bd7a89d, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
  - textoDaEscolha: "O celular j\xE1 estava desbloqueado, ent\xE3o tentei ver de
      quem era."
    proximoNo: {fileID: 11400000, guid: aef9669d132710a4aa4a47db8bd7a89d, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
  - textoDaEscolha: "Achei o celular e a bateria estava acabando, ent\xE3o coloquei
      pra carregar para encontrar o dono."
    proximoNo: {fileID: 11400000, guid: aef9669d132710a4aa4a47db8bd7a89d, type: 2}
    encerraPuzzle: 0
    jogadorGanhou: 0
